generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  dmName      String?
  description String?
  currentArc  String?
  startDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    SessionPlan[]
  storylines  Storyline[]
  npcs        NPC[]
  secrets     SecretGoal[]
  journals    JournalEntry[]
  characters  Character[]
  locations   Location[]
  factions    Faction[]
  wishlists     MagicItemWishlist[]
  agentLogs     AgentLog[]
  noteFolders   NoteFolder[]
  noteDocuments NoteDocument[]
}

model SessionPlan {
  id               String   @id @default(cuid())
  sessionNumber    Int
  title            String
  date             DateTime?
  status           String   @default("draft") // draft, planning, ready, in_progress, completed
  summary          String?
  aiNarrative      String?  // AI-generated dashboard header narrative
  aiBadge          String?  // AI-generated thematic badge label
  aiSummary        String?  // AI-generated session summary fallback
  keyBeats         String?  // JSON array
  encounters       String?  // JSON array
  hooks            String?  // JSON array
  npcAppearances   String?  // JSON array of NPC ids
  locations        String?  // JSON array
  playerNotes      String?  // JSON array
  contingencies    String?  // JSON array
  improvPrompts    String?  // JSON array
  reminders        String?  // JSON array
  checklist        String?  // JSON array
  template         String?  // tavern, travel, mystery, combat, political
  liveLog          String?  // JSON array of {timestamp, entry} — legacy typed notes
  transcript       String?  // accumulated Deepgram transcript (appended per chunk)
  liveExtractions  String?  // JSON — accumulated real-time chunk extraction results
  runningSummary   String?  // AI-maintained rolling summary of the session so far
  keyEvents        String?  // JSON array of {type, description} — final synthesis output
  recapForNext     String?  // "Previously on..." paragraph — final synthesis output
  synthesis        String?  // Full SessionSynthesis JSON — persisted at session end
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  storylineLinks   SessionStoryline[]
  npcLinks         SessionNPC[]
  secretLinks      SessionSecret[]
  journalEntries   JournalEntry[]
  agentLogs        AgentLog[]
}

model AgentLog {
  id         String      @id @default(cuid())
  agent      String      // e.g. "chronicler"
  action     String      // e.g. "chunk_processed" | "session_synthesized"
  sessionId  String?
  session    SessionPlan? @relation(fields: [sessionId], references: [id])
  data       String?     // JSON — result summary
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  createdAt  DateTime    @default(now())
}

model Storyline {
  id              String   @id @default(cuid())
  title           String
  summary         String?
  status          String   @default("active") // active, resolved, dormant, failed
  arcName         String?
  urgency         String   @default("medium")
  nextDevelopment String?
  notes           String?
  tags            String?  // JSON array
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events          StoryEvent[]
  npcLinks        StorylineNPC[]
  secretLinks     StorylineSecret[]
  sessionLinks    SessionStoryline[]
}

model StoryEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String?
  session     Int?
  type        String   @default("event")
  storylineId String
  storyline   Storyline @relation(fields: [storylineId], references: [id])
  createdAt   DateTime  @default(now())
}

model NPC {
  id              String   @id @default(cuid())
  name            String
  age             String?
  appearance      String?
  race            String?
  role            String?
  faction         String?
  disposition     String   @default("neutral")
  status          String   @default("alive")
  location        String?
  goals           String?
  secrets         String?
  relationships   String?
  firstAppearance Int?
  lastAppearance  Int?
  voiceNotes      String?
  dmNotes         String?
  storyRelevance  String?
  isPlayerKnown   Boolean  @default(true)
  isPinned        Boolean  @default(false)
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storylineLinks  StorylineNPC[]
  sessionLinks    SessionNPC[]
  secretLinks     NPCSecret[]
}

model SecretGoal {
  id          String   @id @default(cuid())
  title       String
  type        String
  owner       String?
  description String?
  visibility  String   @default("dm_only")
  urgency     String   @default("medium")
  status      String   @default("active")
  progress    Int      @default(0)
  notes       String?
  isPinned    Boolean  @default(false)
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storylineLinks  StorylineSecret[]
  sessionLinks    SessionSecret[]
  npcLinks        NPCSecret[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("session_recap")
  tags        String?
  isPinned    Boolean  @default(false)
  sessionId   String?
  session     SessionPlan? @relation(fields: [sessionId], references: [id])
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Character {
  id            String   @id @default(cuid())
  name          String
  className     String?
  subclass      String?
  race          String?
  level         Int      @default(1)
  background    String?
  backstory     String?
  personality   String?
  bonds         String?
  flaws         String?
  ideals        String?
  currentGoals  String?
  relationships String?
  status        String   @default("active")
  notes         String?
  isPlayerCharacter Boolean @default(true)
  playerName    String?
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  backgrounds   CharacterBackground[]
  wishlists     MagicItemWishlist[]
}

model CharacterBackground {
  id                String   @id @default(cuid())
  backgroundText    String?
  keyHistory        String?
  plotHooks         String?
  unresolvedThreads String?
  linkedNPCs        String?
  characterId       String
  character         Character @relation(fields: [characterId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model MagicItemWishlist {
  id          String   @id @default(cuid())
  itemName    String
  rarity      String   @default("uncommon")
  characterId String
  character   Character @relation(fields: [characterId], references: [id])
  reason      String?
  status      String   @default("rumored")
  storyHook   String?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String?
  region      String?
  notes       String?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  createdAt   DateTime @default(now())
}

model Faction {
  id          String   @id @default(cuid())
  name        String
  description String?
  alignment   String?
  goals       String?
  status      String   @default("active")
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  createdAt   DateTime @default(now())
}

// Junction tables
model SessionStoryline {
  sessionId   String
  storylineId String
  session     SessionPlan @relation(fields: [sessionId], references: [id])
  storyline   Storyline   @relation(fields: [storylineId], references: [id])
  @@id([sessionId, storylineId])
}

model SessionNPC {
  sessionId String
  npcId     String
  session   SessionPlan @relation(fields: [sessionId], references: [id])
  npc       NPC         @relation(fields: [npcId], references: [id])
  @@id([sessionId, npcId])
}

model SessionSecret {
  sessionId String
  secretId  String
  session   SessionPlan @relation(fields: [sessionId], references: [id])
  secret    SecretGoal  @relation(fields: [secretId], references: [id])
  @@id([sessionId, secretId])
}

model StorylineNPC {
  storylineId String
  npcId       String
  storyline   Storyline @relation(fields: [storylineId], references: [id])
  npc         NPC       @relation(fields: [npcId], references: [id])
  @@id([storylineId, npcId])
}

model StorylineSecret {
  storylineId String
  secretId    String
  storyline   Storyline  @relation(fields: [storylineId], references: [id])
  secret      SecretGoal @relation(fields: [secretId], references: [id])
  @@id([storylineId, secretId])
}

model NPCSecret {
  npcId    String
  secretId String
  npc      NPC        @relation(fields: [npcId], references: [id])
  secret   SecretGoal @relation(fields: [secretId], references: [id])
  @@id([npcId, secretId])
}

model NoteFolder {
  id           String         @id @default(cuid())
  name         String
  slug         String
  sortOrder    Int            @default(0)
  allowNewDocs Boolean        @default(false)
  campaignId   String
  campaign     Campaign       @relation(fields: [campaignId], references: [id])
  documents    NoteDocument[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([campaignId, slug])
}

model NoteDocument {
  id          String      @id @default(cuid())
  title       String
  slug        String
  content     Json?
  sortOrder   Int         @default(0)
  isDeletable Boolean     @default(false)
  folderId    String?
  folder      NoteFolder? @relation(fields: [folderId], references: [id])
  campaignId  String
  campaign    Campaign    @relation(fields: [campaignId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([campaignId, slug])
}
